      "using vf = vector<float>;",
      "using vll = vector<long long>;",
      "using vvi = vector<vi>;",
      "using vvf = vector<vf>;",
      "using vvll = vector<vll>;",
      ""
    ],
    "description": "Vector Aliases snip"
  },
